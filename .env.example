# ============================================
# ChatBook 환경변수 템플릿
# 이 파일을 .env 로 복사하여 사용하세요.
# ============================================

# AI Provider API Keys
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 데모 모드 (true: API 키 없이 목업 응답으로 동작)
USE_DEMO_MODE=true

# CORS 허용 오리진 (쉼표로 구분, 프로덕션 배포 시 실제 도메인 추가)
# 예: CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# NEXT_PUBLIC_API_URL 은 프론트엔드 전용 환경변수입니다.
# chatbook/frontend/.env.local 파일에 설정하세요:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
# Docker 배포 시 docker-compose.yml 의 build args 를 통해 주입됩니다.

# 데이터베이스
DATABASE_URL=sqlite:///app/data/chatbook.db

# ============================================
# Docker Compose 전용 환경변수
# ============================================
# 백엔드 호스트 포트 (기본값: 8000)
BACKEND_PORT=8000

# 프론트엔드 호스트 포트 (기본값: 3000)
FRONTEND_PORT=3000

# 브라우저가 직접 접근할 백엔드 URL (SSE 스트리밍용, 기본값: http://localhost:8000)
# Docker 환경에서는 호스트에서 접근 가능한 URL로 설정
NEXT_PUBLIC_API_URL=http://localhost:8000

# Docker 내부 통신용 백엔드 URL (기본값: http://backend:8000)
# Docker 네트워크 내에서 backend 서비스 컨테이너 간 통신에 사용
BACKEND_INTERNAL_URL=http://backend:8000
